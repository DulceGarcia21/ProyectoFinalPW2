<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Conductores</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('partials/menu') %>
    <div class="main-content">
        <div class="page-header">
            <h1>Lista de Conductores</h1>
            <% if(usuario && usuario.rol === 'admin'){ %>
                <div class="header-buttons">
                    <button type="button" onclick="toggleFormulario()" class="btn-agregar">
                        + Agregar conductor
                    </button>
                    <a href="/conductores/descargar/json" class="btn-agregar">
                        Exportar
                    </a>
                </div>
            <% } %>
        </div>

        <% if(usuario && usuario.rol === 'admin'){ %>
            <div id="formularioConductores" class="formulario-oculto">
                <form action="/conductores/agregar" method="POST">
                    <label>Nombre:</label>
                    <input type="text" name="nombre" required>

                    <label>Teléfono:</label>
                    <input type="text" name="telefono">

                    <label>Licencia:</label>
                    <input type="text" name="licencia">

                    <label>Estado:</label>
                    <select name="estado" required>
                        <option value="activo">Activo</option>
                        <option value="inactivo">Inactivo</option>
                    </select>
                    <button type="submit">Agregar</button>
                </form>
            </div>
        <% } %>

        <table>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Teléfono</th>
                <th>Licencia</th>
                <th>Estado</th>
                <th class="col-acciones">Acciones</th>
            </tr>

            <% conductores.forEach(conductor => { %>
                <tr>
                    <td><%= conductor.id_conductor %></td>
                    <td><%= conductor.nombre %></td>
                    <td><%= conductor.telefono %></td>
                    <td><%= conductor.licencia %></td>
                    <td><%= conductor.estado %></td>
                    <td class="col-acciones">
                        <% if (usuario && usuario.rol === 'admin') { %>
                            <div class="acciones">
                                <a href="/conductores/editar/<%= conductor.id_conductor %>"class="btn-editar">
                                    Editar
                                </a>
                                <form
                                    action="/conductores/eliminar/<%= conductor.id_conductor %>"method="POST">
                                    <button type="submit">Eliminar</button>
                                </form>
                            </div>
                        <% } %>
                    </td>
                </tr>
            <% }) %>
        </table>
    </div>
    <script>
    function toggleFormulario(){
        const formulario = document.getElementById('formularioConductores');
        formulario.classList.toggle('mostrar-formulario');
    }
    </script>
</body>
</html>