<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bicitaxis</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('partials/menu') %>
    <h1>Lista de Bicitaxis</h1>

    <% if (usuario && usuario.rol === 'admin') { %>
    <h2>Agregar bicitaxi</h2>
    <form action="/bicitaxis/agregar" method="POST">
        <label>Matrícula:</label>
        <input type="text" name="matricula" maxlength="5" required>

        <label>Estado:</label>
        <select name="estado" required>
            <option value="disponible">Disponible</option>
            <option value="fuera_servicio">Fuera de servicio</option>
            <option value="mantenimiento">Mantenimiento</option>
            <option value="en_viaje">En viaje</option>
        </select>

        <label>Descripción:</label>
        <textarea name="descripcion"></textarea>

        <label>Conductor:</label>
        <select name="id_conductor">
            <option value="">
                Sin conductor
            </option>
            <% conductores.forEach(conductor => { %>
                <option value="<%= conductor.id_conductor %>">
                    <%= conductor.nombre %>
                </option>
            <% }) %>
        </select>
        <button type="submit">Agregar</button>
    </form>
    <% } %>

    <table border="1">

        <tr>
            <th>Matrícula</th>
            <th>Estado</th>
            <th>Descripción</th>
            <th>Acciones</th>
        </tr>

        <% bicitaxis.forEach(bicitaxi => { %>

            <tr>
                <td><%= bicitaxi.matricula %></td>
                <td><%= bicitaxi.estado %></td>
                <td><%= bicitaxi.descripcion %></td>
                <td>
                    <% if (usuario && usuario.rol === 'admin') { %>
                        <form action="/bicitaxis/eliminar/<%= bicitaxi.matricula %>" method="POST">
                            <button type="submit">
                                Eliminar
                            </button>
                        </form>
                    <% } %>
                </td>
            </tr>
        <% }) %>
    </table>
</body>
</html>