<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Mantenimientos</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

    <%- include('partials/menu') %>
    <div class="main-content">
        <h1>Mantenimientos</h1>
        <% if (usuario && usuario.rol === 'admin') { %>
            <h2>Agregar mantenimiento</h2>
            <form action="/mantenimientos/agregar" method="POST">

                <label>Bicitaxi:</label>
                <select name="matricula_bicitaxi" required>
                    <% bicitaxis.forEach(bicitaxi => { %>
                        <option value="<%= bicitaxi.matricula %>">
                            <%= bicitaxi.matricula %>
                        </option>
                    <% }) %>
                </select>

                <label>Descripción:</label>
                <textarea name="descripcion" required></textarea>

                <label>Fecha inicio:</label>
                <input type="date" name="fecha_inicio" required>

                <label>Fecha fin:</label>
                <input type="date" name="fecha_fin">

                <label>Costo:</label>
                <input type="number" step="0.01" name="costo">

                <label>Estado:</label>
                <select name="estado" required>
                    <option value="pendiente">Pendiente</option>
                    <option value="en_proceso">En proceso</option>
                    <option value="terminado">Terminado</option>
                </select>
                <button type="submit">Agregar</button>
            </form>
        <% } %>

        <h2>Lista de mantenimientos</h2>

        <table>
            <tr>
                <th>ID</th>
                <th>Bicitaxi</th>
                <th>Descripción</th>
                <th>Inicio</th>
                <th>Fin</th>
                <th>Costo</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>

            <% mantenimientos.forEach(mantenimiento => { %>
                <tr>
                    <td><%= mantenimiento.id_mantenimiento %></td>
                    <td><%= mantenimiento.matricula_bicitaxi %></td>
                    <td><%= mantenimiento.descripcion %></td>
                    <td><%= new Date(mantenimiento.fecha_inicio).toLocaleDateString('es-MX') %></td>
                    <td><%= mantenimiento.fecha_fin
                            ? new Date(mantenimiento.fecha_fin).toLocaleDateString('es-MX')
                            : 'Sin finalizar'
                        %>
                    </td> 
                    <td><%= mantenimiento.costo ? '$' + mantenimiento.costo : 'Sin costo' %></td>
                    <td><%= mantenimiento.estado %></td>
                    <td>
                        <% if (usuario && usuario.rol === 'admin') { %>
                            <div class="acciones">
                                <a href="/mantenimientos/editar/<%= mantenimiento.id_mantenimiento %>"class="btn-editar">
                                    Editar
                                </a>
                                <form action="/mantenimientos/eliminar/<%= mantenimiento.id_mantenimiento %>" method="POST">
                                    <button type="submit">Eliminar</button>
                                </form>
                            </div>
                        <% } %>
                    </td>
                </tr>
            <% }) %>
        </table>
    </div>
</body>
</html>