<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Login</title>
</head>

<body>

    <h1>Iniciar Sesión</h1>

    <% if (error) { %>
        <p style="color:red;">
            <%= error %>
        </p>
    <% } %>

    <form action="/login" method="POST">

        <label>Correo:</label>
        <input type="email" name="correo" required>

        <br><br>

        <label>Contraseña:</label>
        <input type="password" name="contraseña" required>

        <br><br>

        <button type="submit">
            Entrar
        </button>

    </form>

</body>

</html>