<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bicitaxis</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('partials/menu') %>

    <div class="main-content">
        <h1>Bicitaxis</h1>

        <div class="cards-dashboard">
            <div class="card">
                <h3>Total bicitaxis</h3>
                <p><%= resumen.total_bicitaxis %></p>
            </div>

            <div class="card">
                <h3>Disponibles</h3>
                <p><%= resumen.disponibles %></p>
            </div>

            <div class="card">
                <h3>En mantenimiento</h3>
                <p><%= resumen.mantenimiento %></p>
            </div>

            <div class="card">
                <h3>En viaje</h3>
                <p><%= resumen.en_viaje %></p>
            </div>

            <div class="card">
                <h3>Reportes nuevos</h3>
                <p><%= resumen.reportes_nuevos %></p>
            </div>

            <div class="card">
                <h3>Mantenimientos pendientes</h3>
                <p><%= resumen.mantenimientos_pendientes %></p>
            </div>

            <div class="card">
                <h3>Conductores activos</h3>
                <p><%= resumen.conductores_activos %></p>
            </div>

            <div class="card">
                <h3>Viajes en curso</h3>
                <p><%= resumen.viajes_en_curso %></p>
            </div>
        </div>
    </div>
</body>
</html>